# ============================================================
# CREDENCIAIS DO PROJETO @cadeiaparamaustratossp
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# ============================================================

# --- Meta / Instagram Graph API ---
# Obter em: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# --- PostgreSQL ---
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:senha@localhost:5432/socialmedia

# --- Configurações Gerais ---
# Ambiente: development | production
ENV=development

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
